        </div>
      </div>
      <div class="readout">
        <div class="stat"><div class="k">카이제곱 χ²</div><div class="v"><span id="chi4Stat">–</span></div></div>
        <div class="stat" id="qBox"><div class="k">감속 매개변수 q</div><div class="v"><span id="qStat">0.5</span></div></div>
