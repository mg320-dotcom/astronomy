const C = 3e5; // 빛의 속도 km/s

/* ----- 공통 유틸 ----- */
const Z = SN.map(p=>p.z), D = SN.map(p=>p.d), E = SN.map(p=>p.e);
const SNnear = SN.filter(p=>p.z<=0.1);            // 허블 법칙이 깔끔한 가까운 초신성
const zline = (()=>{const a=[];for(let z=0;z<=1.8;z+=0.01)a.push(+z.toFixed(3));return a;})();
const znear = (()=>{const a=[];for(let z=0;z<=0.105;z+=0.002)a.push(+z.toFixed(3));return a;})();

const LAYOUT = (title)=>({
  title:{text:title,font:{color:'#dfe7ff',size:16}},
  paper_bgcolor:'rgba(0,0,0,0)', plot_bgcolor:'#0c1326',
  font:{color:'#9fb0d8'}, margin:{l:70,r:20,t:46,b:55},
  xaxis:{title:'적색편이 z (멀어지는 정도)',gridcolor:'#1f2b50',zerolinecolor:'#2a3a66',color:'#9fb0d8'},
  yaxis:{title:'거리 d (Mpc)',gridcolor:'#1f2b50',zerolinecolor:'#2a3a66',color:'#9fb0d8'},
  legend:{x:0.02,y:0.98,bgcolor:'rgba(22,31,61,.7)',bordercolor:'#2a3a66',borderwidth:1},
  hovermode:'closest'
});
const CONFIG={responsive:true,displayModeBar:false};

function dataTrace(showErr,pts){
  pts=pts||SN;
  return {x:pts.map(p=>p.z),y:pts.map(p=>p.d),
    error_y:showErr?{type:'data',array:pts.map(p=>p.e),visible:true,color:'rgba(77,182,255,.35)',thickness:1,width:0}:{visible:false},
    mode:'markers',type:'scatter',name:'초신성 관측 데이터',
    marker:{color:'#4db6ff',size:6,line:{color:'#0a1a3a',width:1},opacity:.85}};
}
// 가중 최소제곱: 직선 d=a*z (원점 통과), 반환 a, H=C/a
function fitLinear(pts){let sxy=0,sxx=0;for(const p of pts){const w=1/(p.e*p.e);sxy+=w*p.z*p.d;sxx+=w*p.z*p.z;}const a=sxy/sxx;return {a,H:C/a};}
// 가중 최소제곱: d=a*z+b*z^2, 반환 H=C/a, q=1-2b/a
function fitQuad(pts){
  let s11=0,s12=0,s22=0,t1=0,t2=0;
  for(const p of pts){const w=1/(p.e*p.e),z=p.z,d=p.d;
    s11+=w*z*z; s12+=w*z*z*z; s22+=w*z*z*z*z; t1+=w*z*d; t2+=w*z*z*d;}
  const det=s11*s22-s12*s12; const a=(t1*s22-t2*s12)/det; const b=(s11*t2-s12*t1)/det;
  return {a,b,H:C/a,q:1-2*b/a};
}
function chi2Linear(H){let s=0;for(const p of SNnear){const m=C*p.z/H;s+=((m-p.d)/p.e)**2;}return s;}
function chi2Quad(H,q){let s=0;for(const p of SN){if(p.z>0.5)continue;const m=C*(p.z+0.5*(1-q)*p.z*p.z)/H;s+=((m-p.d)/p.e)**2;}return s;}

/* ===================== 활동 1 ===================== */
let p1err=true, p1drawn=false;
function drawPlot1(){
  p1drawn=true;
  Plotly.newPlot('plot1',[dataTrace(p1err)],LAYOUT('실제 Ia형 초신성 206개의 적색편이–거리 데이터'),CONFIG);
}
function togglePlot1Err(){p1err=!p1err; if(p1drawn)drawPlot1();}

/* ===================== 활동 2 ===================== */
function modelLinear(H){return znear.map(z=>C*z/H);}
function updatePlot2(){
  const H=+document.getElementById('Hslider').value;
  document.getElementById('Hval').textContent=H;
  document.getElementById('Hstat').textContent=H;
  const chi=chi2Linear(H);
  document.getElementById('chiStat').textContent=chi.toFixed(0);
  // 색: χ²가 작을수록 초록
  const best=chi2Linear(fitLinear(SNnear).H);
  const box=document.getElementById('chiBox');
  box.className='stat'+(chi<best*1.15?' good':'');
  const traces=[dataTrace(false,SNnear),
    {x:znear,y:modelLinear(H),mode:'lines',type:'scatter',name:'허블 법칙 직선 d=cz/H',line:{color:'#ff5d6c',width:3}}];
  const lay=LAYOUT('가까운 초신성(z ≤ 0.1)으로 측정한 허블 상수 H = '+H+' km/s/Mpc');
  lay.xaxis.range=[0,0.105];
  Plotly.react('plot2',traces,lay,CONFIG);
}
function bestFitLinear(){
  const H=fitLinear(SNnear).H;
  const s=document.getElementById('Hslider');
  // 애니메이션으로 슬라이더 이동
  let cur=+s.value; const tgt=Math.round(H*2)/2;
  const iv=setInterval(()=>{cur+= (tgt-cur)*0.25; if(Math.abs(tgt-cur)<0.3){cur=tgt;clearInterval(iv);} s.value=cur; updatePlot2();},30);
}
function resetH(){document.getElementById('Hslider').value=70;updatePlot2();}

/* ===================== 활동 3 ===================== */
let p3resid=false;
function drawPlot3(){
  const low=SN.filter(p=>p.z>=0.01&&p.z<=0.09);
  const fit=fitLinear(low);
  document.getElementById('HlowStat').textContent=fit.H.toFixed(1);
  const yline=zline.map(z=>C*z/fit.H);
  if(!p3resid){
    const traces=[
      dataTrace(false),
      {x:zline,y:yline,mode:'lines',type:'scatter',name:'가까운 데이터로 정한 예상선(연장)',line:{color:'#ff5d6c',width:3,dash:'solid'}},
      {x:SN.filter(p=>p.z<=0.09).map(p=>p.z),y:SN.filter(p=>p.z<=0.09).map(p=>p.d),mode:'markers',type:'scatter',name:'기준이 된 가까운 초신성',marker:{color:'#46d39a',size:7,line:{color:'#06351f',width:1}}}
    ];
    Plotly.react('plot3',traces,LAYOUT('가까운 데이터로 그은 직선을 먼 우주까지 연장'),CONFIG);
  }else{
    // 잔차: 실제 d - 예상 d
    const res=SN.map(p=>p.d - C*p.z/fit.H);
    const lay=LAYOUT('예상선 대비 실제 거리 차이 (양수=예상보다 멀다=어둡다)');
    lay.yaxis.title='실제 거리 − 예상 거리 (Mpc)';
    Plotly.react('plot3',[
      {x:Z,y:res,mode:'markers',type:'scatter',name:'예상과의 차이',
        marker:{color:res.map(r=>r>=0?'#ff5d6c':'#4db6ff'),size:6,line:{color:'#0a1a3a',width:1}}},
      {x:[0,1.8],y:[0,0],mode:'lines',type:'scatter',name:'예상선(차이=0)',line:{color:'#9fb0d8',width:2,dash:'dot'}}
    ],lay,CONFIG);
  }
}
function togglePlot3Residual(){p3resid=!p3resid;drawPlot3();}

/* ===================== 활동 4 ===================== */
function modelQuad(H,q){return zline.filter(z=>z<=0.55).map(z=>C*(z+0.5*(1-q)*z*z)/H);}
function updatePlot4(){
  const H=+document.getElementById('H4slider').value;
  const q=+document.getElementById('qslider').value;
  document.getElementById('H4val').textContent=H;
  document.getElementById('qval').textContent=q.toFixed(2);
  document.getElementById('qStat').textContent=q.toFixed(2);
  const chi=chi2Quad(H,q);
  document.getElementById('chi4Stat').textContent=chi.toFixed(0);
  // 판정
  const v=document.getElementById('verdict'); const vb=document.getElementById('verdictBox'); const qb=document.getElementById('qBox');
  if(q<-0.05){v.textContent='가속 팽창 🚀';v.style.color='#ff5d6c';qb.className='stat good';}
  else if(q>0.05){v.textContent='감속 팽창 🛑';v.style.color='#4db6ff';qb.className='stat';}
  else{v.textContent='거의 일정';v.style.color='#9fb0d8';qb.className='stat';}
  const zx=zline.filter(z=>z<=0.55);
  const traces=[dataTrace(false),
    {x:zx,y:modelQuad(H,q),mode:'lines',type:'scatter',name:'2차(곡선) 모델',line:{color:'#9d7bff',width:3}},
    {x:zx,y:zx.map(z=>C*z/H),mode:'lines',type:'scatter',name:'비교용 직선(가속·감속 없음)',line:{color:'#ff5d6c',width:2,dash:'dash'}}];
  const lay=LAYOUT('곡선 모델  H='+H+',  q='+q.toFixed(2));
  lay.xaxis.range=[0,0.56];
  Plotly.react('plot4',traces,lay,CONFIG);
}
function bestFitQuad(){
  const fit=fitQuad(SN.filter(p=>p.z<=0.5));
  const Hs=document.getElementById('H4slider'), qs=document.getElementById('qslider');
  const Ht=Math.max(50,Math.min(100,Math.round(fit.H*2)/2));
  const qt=Math.max(-2,Math.min(1.5,Math.round(fit.q*20)/20));
  let cH=+Hs.value, cq=+qs.value;
  const iv=setInterval(()=>{
    cH+=(Ht-cH)*0.25; cq+=(qt-cq)*0.25;
    if(Math.abs(Ht-cH)<0.3&&Math.abs(qt-cq)<0.02){cH=Ht;cq=qt;clearInterval(iv);
      // 암흑에너지 안내
      const dark=0.15-fit.q;
      const note=document.getElementById('darkNote'), msg=document.getElementById('darkMsg');
      note.style.display='block';
      msg.innerHTML='데이터에 가장 잘 맞는 값은 <b>H ≈ '+fit.H.toFixed(1)+' km/s/Mpc</b>, '+
        '<b style="color:#ff5d6c">q ≈ '+fit.q.toFixed(2)+'</b> 입니다. q가 <b>음수</b>이므로 우주는 <b style="color:#ff5d6c">가속 팽창</b>! '+
        '이 결과는 우주 에너지의 약 <b style="color:#9d7bff">'+(dark*100).toFixed(0)+'%</b> 이상이 '+
        '중력에 반하는 <span style="color:#9d7bff;font-weight:700">암흑에너지</span>임을 시사합니다.';
    }
    Hs.value=cH; qs.value=cq; updatePlot4();
  },30);
}
function resetQuad(){document.getElementById('H4slider').value=70;document.getElementById('qslider').value=0.5;
  document.getElementById('darkNote').style.display='none';updatePlot4();}

/* ===================== 초기 렌더 ===================== */
window.addEventListener('load',()=>{
  drawPlot1();
  updatePlot2();
  drawPlot3();
  updatePlot4();
});
</script>
</body>
